# Copy to .env for local dev. On Netlify, set the same names in Site settings → Environment.
# Use the publishable key from Supabase → Project Settings → API (sb_publishable_… or legacy anon JWT).

SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-publishable-key-here

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key-here
VITE_SITE_URL=https://your-netlify-site.netlify.app
